{
  "name": "@getmcpm/cli",
  "version": "0.15.0",
  "mcpName": "io.github.getmcpm/cli",
  "description": "MCP package manager — search, install, and audit MCP servers across Claude Desktop, Cursor, VS Code, and Windsurf",
  "type": "module",
  "bin": {
    "mcpm": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "dogfood:confine": "pnpm build && bash scripts/dogfood-confine.sh",
    "dogfood:release": "bash scripts/dogfood-release.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "package-manager",
    "cli",
    "ai",
    "security",
    "claude",
    "cursor",
    "vscode"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getmcpm/cli"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.5",
      "hono": "^4.12.25",
      "@hono/node-server": "1.19.14",
      "fast-uri": "^3.1.2",
      "postcss": "^8.5.10",
      "ip-address": "^10.1.1",
      "esbuild": "^0.28.1"
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sigstore/bundle": "^4.0.0",
    "@sigstore/protobuf-specs": "^0.5.1",
    "@sigstore/verify": "^3.1.1",
    "@types/proper-lockfile": "^4.1.4",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "ora": "^9.4.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.8.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
